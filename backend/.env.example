# ============================================
# SNEAKER STORE - BACKEND ENVIRONMENT VARIABLES
# ============================================

# MongoDB Connection
# Using MongoDB Atlas cloud database (recommended for production)
# Get your connection string from: https://cloud.mongodb.com -> Clusters -> Connect -> Drivers
# NOTE: Use DIRECT connection format (not SRV+srv) to avoid DNS issues on some networks
# Direct Format: mongodb://username:password@shard-00.hostname,shard-01.hostname,shard-02.hostname/database?ssl=true&authSource=admin&retryWrites=true&w=majority
# SRV Format (if direct doesn't work): mongodb+srv://username:password@cluster-name.mongodb.net/database?retryWrites=true&w=majority
MONGODB_URI=mongodb://username:password@cluster-shard-00.mongodb.net,cluster-shard-01.mongodb.net,cluster-shard-02.mongodb.net/sneaker-store?ssl=true&authSource=admin&retryWrites=true&w=majority

# JWT Secret
# Generate a strong random string for production (min 32 characters)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ============== PAYMENT GATEWAYS ==============
# Razorpay Configuration
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxx

# Stripe Payment Keys
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLIC_KEY
STRIPE_WEBHOOK_SECRET=whsec_test_YOUR_WEBHOOK_SECRET

# Server Configuration
PORT=5000
NODE_ENV=development

# ============== EMAIL CONFIGURATION ==============
# Choose your email service provider (recommended: sendgrid)
# EMAIL_SERVICE options: gmail, sendgrid, mailgun, aws-ses, brevo
EMAIL_SERVICE=sendgrid
EMAIL_FROM=noreply@sneakhub.com

# ========== EMAIL SERVICE OPTIONS ==========

# OPTION 1: SendGrid (RECOMMENDED for production)
# Sign up: https://sendgrid.com/
# Get API Key from: Settings → API Keys → Create API Key
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# OPTION 2: Mailgun
# Sign up: https://mailgun.com/
# Get API Key from: Domain Settings → API Security
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=your_domain.mailgun.org

# OPTION 3: AWS SES (Simple Email Service)
# Get credentials from: AWS Console → IAM → Create User with SES permissions
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1

# OPTION 4: Brevo (formerly SendinBlue)
# Sign up: https://www.brevo.com/
# Get credentials from: SMTP & API → SMTP
BREVO_SMTP_USER=your_brevo_email@brevo.com
BREVO_SMTP_PASSWORD=your_brevo_password

# OPTION 5: Gmail SMTP (fallback, NOT recommended for production)
# Note: Gmail has strict security policies and may block production servers
# Only use for development or if other services unavailable
# Only if EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx  # 16-char App Password only

# Frontend URL for email links and tracking
FRONTEND_URL=http://localhost:3000

# ============================================
# SETUP INSTRUCTIONS
# ============================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Update all values with your actual credentials
# 3. Never commit .env to version control
# 4. For production, use strong, unique values
# 5. For EMAIL setup, see EMAIL_SETUP_GUIDE.md
# ============================================
